# ╔══════════════════════════════════════════════════════════════════════╗
# ║  RoziRakshak AI — Environment Variables                            ║
# ║  Copy this file to .env.local and fill in the real values.         ║
# ║      cp .env.example .env.local                                    ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Firebase Client SDK (public, exposed to the browser) ──────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin SDK (server-only, NEVER exposed to the browser) ────
# These come from your Firebase service-account JSON.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Cloudflare R2 (server-only, NEVER exposed to browser) ─────────────────────
# Used for presigned URL generation in /api/upload/face
# R2 Account ID: found in Cloudflare dashboard → R2 → Overview
R2_ACCOUNT_ID=
# R2 API token credentials (create a token with Object Read & Write permissions)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Name of your R2 bucket (e.g. "rozirakshak-faces")
R2_BUCKET_NAME=

# ── Google Cloud Vision API (server-only, NEVER expose .env value to browser) ─
# Used for face landmark comparison during claim re-verification.
# Create an API key in Google Cloud Console restricted to "Cloud Vision API" only.
# Then copy the value into NEXT_PUBLIC_GOOGLE_CLOUD_VISION_API_KEY so the
# client-side comparison can call vision.googleapis.com/v1/images:annotate.
GOOGLE_CLOUD_VISION_API_KEY=
NEXT_PUBLIC_GOOGLE_CLOUD_VISION_API_KEY=
