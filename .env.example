# ============================================
# FIREBASE CLIENT SDK (Browser)
# Get these from Firebase Console → Project Settings → Your apps → Web app
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# FIREBASE ADMIN SDK (Server-side)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
# ============================================
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# IMPORTANT: Keep \n as literal \n (don't convert to actual newlines), wrap in quotes
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# ============================================
# RAZORPAY (Payment Gateway)
# Get these from Razorpay Dashboard → Settings → API Keys
# ============================================
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_ACCOUNT_NUMBER=XXXXXXXXXXXXXXXX

# ============================================
# ML SERVICE
# ============================================
# Local development
NEXT_PUBLIC_ML_SERVICE_URL=http://localhost:8000
# Production (after deploying to Render)
# NEXT_PUBLIC_ML_SERVICE_URL=https://your-ml-service.onrender.com

# ============================================
# MOCK AUTH (Development Only - DO NOT USE IN PRODUCTION)
# ============================================
NEXT_PUBLIC_MOCK_AUTH_ENABLED=false

# ============================================
# DEVELOPMENT MODE (Test Phone Numbers)
# Set to true to use Firebase test phone numbers (no SMS sent)
# Add test numbers in Firebase Console → Authentication → Sign-in method
# Example: +919999999999 with OTP 123456
# ============================================
NEXT_PUBLIC_DEV_MODE=true
