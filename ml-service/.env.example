# Service Configuration
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Model Paths
MODELS_DIR=./models
DATA_DIR=./data

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-firebase-project.cloudfunctions.net

# Model Versions (optional, defaults to v1)
PREMIUM_MODEL_VERSION=v1
FORECAST_MODEL_VERSION=v1
FRAUD_MODEL_VERSION=v1
CONFIDENCE_MODEL_VERSION=v1
